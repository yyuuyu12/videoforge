{
  "name": "videoforge",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "server",
    "dashboard"
  ],
  "scripts": {
    "postinstall": "npm install --prefix workspaces --ignore-scripts --no-audit --no-fund",
    "server": "node --watch server/src/index.js",
    "dashboard": "npm run dev --workspace dashboard",
    "build": "npm run build --workspace dashboard",
    "test": "node --import ./server/test-setup.js --test server/src/*.test.js",
    "start": "node server/src/index.js"
  }
}
